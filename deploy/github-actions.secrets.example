# Copy to deploy/github-actions.secrets and fill in (never commit that file).

DEPLOY_HOST=
DEPLOY_USER=root
DEPLOY_SSH_KEY_FILE=
# Optional: PAT with read:packages. Leave empty — Actions uses GITHUB_TOKEN by default.
GHCR_TOKEN=

DEPLOY_PATH=/opt/city-airport-taxis-backend
DEPLOY_PORT=22
DEPLOY_PORT_APP=5000
